# ============================================
# Batería de Preguntas - Environment Variables
# ============================================

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bateria_preguntas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bateria_preguntas

# --- JWT ---
JWT_SECRET=CHANGE_ME_to_a_random_64_char_string
JWT_REFRESH_SECRET=CHANGE_ME_to_another_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Server ---
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Logging ---
LOG_LEVEL=info
