// ============================================
// Prisma Schema - Batería de Preguntas
// Clean Architecture: Domain layer models
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────
enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TestType {
  QUICK
  TOPIC
  EXAM_SIMULATION
  ERROR_REVIEW
  CUSTOM
}

enum AchievementType {
  STREAK
  ACCURACY
  VOLUME
  MASTERY
  SPEED
}

// ─── User ────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(100)
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash")
  role          Role     @default(USER)
  examDate      DateTime? @map("exam_date")
  darkMode      Boolean  @default(false) @map("dark_mode")
  notifications Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  progress       UserProgress[]
  mistakes       Mistake[]
  tests          Test[]
  testAnswers    TestAnswer[]
  streak         Streak?
  studyPlans     StudyPlan[]
  achievements   UserAchievement[]
  bookmarks      Bookmark[]
  sessions       Session[]

  @@map("users")
}

// ─── Session (refresh tokens) ────────────────
model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Topic ───────────────────────────────────
model Topic {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(200)
  description String?  @db.Text
  order       Int      @default(0)
  icon        String?  @db.VarChar(50)
  color       String?  @db.VarChar(7)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  questions Question[]

  @@map("topics")
}

// ─── Question ────────────────────────────────
model Question {
  id           String     @id @default(uuid())
  topicId      String     @map("topic_id")
  questionText String     @map("question_text") @db.Text
  options      Json       // Array of strings
  correctIndex Int        @map("correct_index")
  explanation  String?    @db.Text
  difficulty   Difficulty @default(MEDIUM)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  topic       Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  progress    UserProgress[]
  mistakes    Mistake[]
  testAnswers TestAnswer[]
  bookmarks   Bookmark[]

  @@index([topicId])
  @@index([difficulty])
  @@map("questions")
}

// ─── User Progress ──────────────────────────
model UserProgress {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  questionId   String   @map("question_id")
  isCorrect    Boolean  @map("is_correct")
  attempts     Int      @default(1)
  lastAttempt  DateTime @default(now()) @map("last_attempt")
  isMastered   Boolean  @default(false) @map("is_mastered")
  responseTime Int?     @map("response_time") // milliseconds
  // Spaced repetition fields
  nextReview   DateTime? @map("next_review")
  easeFactor   Float    @default(2.5) @map("ease_factor")
  interval     Int      @default(1) // days

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@index([nextReview])
  @@map("user_progress")
}

// ─── Mistakes (Error Bank) ──────────────────
model Mistake {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  questionId   String   @map("question_id")
  mistakeCount Int      @default(1) @map("mistake_count")
  lastMistake  DateTime @default(now()) @map("last_mistake")
  isResolved   Boolean  @default(false) @map("is_resolved")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("mistakes")
}

// ─── Test ────────────────────────────────────
model Test {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  type           TestType @default(QUICK)
  score          Float    @default(0)
  totalQuestions Int      @map("total_questions")
  correctAnswers Int      @default(0) @map("correct_answers")
  timeSpent      Int      @default(0) @map("time_spent") // seconds
  timeLimit      Int?     @map("time_limit") // seconds
  penalizeErrors Boolean  @default(false) @map("penalize_errors")
  isCompleted    Boolean  @default(false) @map("is_completed")
  createdAt      DateTime @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers TestAnswer[]

  @@index([userId])
  @@index([createdAt])
  @@map("tests")
}

// ─── Test Answer ─────────────────────────────
model TestAnswer {
  id            String   @id @default(uuid())
  testId        String   @map("test_id")
  userId        String   @map("user_id")
  questionId    String   @map("question_id")
  selectedIndex Int?     @map("selected_index")
  isCorrect     Boolean? @map("is_correct")
  responseTime  Int?     @map("response_time") // ms
  answeredAt    DateTime? @map("answered_at")

  test     Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([testId, questionId])
  @@index([testId])
  @@map("test_answers")
}

// ─── Streak ──────────────────────────────────
model Streak {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  currentStreak Int      @default(0) @map("current_streak")
  maxStreak     Int      @default(0) @map("max_streak")
  lastStudyDate DateTime? @map("last_study_date")
  // No-fail mode streaks
  currentNoFail Int      @default(0) @map("current_no_fail")
  maxNoFail     Int      @default(0) @map("max_no_fail")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

// ─── Study Plan ──────────────────────────────
model StudyPlan {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  date        DateTime @db.Date
  topicIds    Json     @map("topic_ids") // Array of topic IDs
  description String?  @db.Text
  isCompleted Boolean  @default(false) @map("is_completed")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("study_plans")
}

// ─── Achievement ─────────────────────────────
model Achievement {
  id          String          @id @default(uuid())
  name        String          @db.VarChar(100)
  description String          @db.Text
  icon        String          @db.VarChar(50)
  type        AchievementType
  threshold   Int             // Value needed to unlock
  isActive    Boolean         @default(true) @map("is_active")

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ─── Bookmark ────────────────────────────────
model Bookmark {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  note       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("bookmarks")
}
